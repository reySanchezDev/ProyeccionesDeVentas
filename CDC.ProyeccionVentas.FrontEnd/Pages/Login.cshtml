@page
@model CDC.ProyeccionVentas.FrontEnd.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    ViewData["HideAppChrome"] = true;
}

<div class="login-page-shell">
    <div class="login-page-logo-card">
        <img src="@Url.Content("~/resources/CdC-Logo-Vertical1.png")" alt="Casa del Café" class="login-page-logo" />
    </div>
    <h1 class="login-page-title">Bienvenido</h1>

    <section class="login-page-card">
        <form method="post" autocomplete="off" class="login-page-form" id="loginForm">
            <div>
                <label asp-for="NumeroEmpleado" class="form-label">Número de empleado</label>
                <input asp-for="NumeroEmpleado" class="form-control" id="numeroEmpleadoInput" placeholder="Número de empleado" autocomplete="off" inputmode="numeric" />
                <span asp-validation-for="NumeroEmpleado" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Contraseña" class="form-label"></label>
                <input asp-for="Contraseña" class="form-control" id="contrasenaInput" placeholder="Contraseña del portal de vacaciones" type="password" autocomplete="off" />
                <span asp-validation-for="Contraseña" class="text-danger small"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mb-0">@Model.ErrorMessage</div>
            }

            <button type="submit" class="btn btn-primary auth-submit">Iniciar sesión</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const numeroEmpleadoInput = document.getElementById("numeroEmpleadoInput");
            const contrasenaInput = document.getElementById("contrasenaInput");

            if (!numeroEmpleadoInput || !contrasenaInput) {
                return;
            }

            numeroEmpleadoInput.addEventListener("keydown", function (event) {
                if (event.key !== "Enter") {
                    return;
                }

                event.preventDefault();
                contrasenaInput.focus();
                contrasenaInput.select();
            });
        });
    </script>
}
