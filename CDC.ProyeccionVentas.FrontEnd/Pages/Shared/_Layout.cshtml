<!DOCTYPE html>
<html lang="es" class="@((string?)ViewData["HtmlClass"] ?? string.Empty)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CDC.ProyeccionVentas.FrontEnd</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CDC.ProyeccionVentas.FrontEnd.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>
<body class="@((string?)ViewData["BodyClass"] ?? string.Empty)">
    @{
        var showSidebar = (bool)(ViewData["ShowSidebar"] ?? false);
        var hideAppChrome = (bool)(ViewData["HideAppChrome"] ?? false);
        var showSidebarShell = showSidebar && !hideAppChrome;
        var appContainerClass = (string?)ViewData["AppContainerClass"] ?? string.Empty;
        var mainContentClass = (string?)ViewData["MainContentClass"] ?? string.Empty;
        var mainBodyClass = (string?)ViewData["MainBodyClass"] ?? string.Empty;
        var pageFrameClass = (string?)ViewData["PageFrameClass"] ?? string.Empty;
        var currentPath = Context?.Request?.Path.Value ?? string.Empty;
        var isSubirDatos = currentPath.EndsWith("/SubirDatos", StringComparison.OrdinalIgnoreCase);
        var isConsulta = currentPath.EndsWith("/ConsultaProyecciones", StringComparison.OrdinalIgnoreCase);
        var isProgramacion = currentPath.EndsWith("/ProgramarPedidosSucursales", StringComparison.OrdinalIgnoreCase);
    }

    <div id="appContainer"
         class="app-container@(showSidebarShell ? " app-with-sidebar" : string.Empty)@(string.IsNullOrWhiteSpace(appContainerClass) ? string.Empty : $" {appContainerClass}")"
         data-sidebar-collapsible="@(showSidebarShell.ToString().ToLowerInvariant())">
        @if (showSidebarShell)
        {
            <nav class="sidebar-cdc" aria-label="Menu principal">
                <div class="sidebar-header">
                    <a asp-page="/Principal" class="logo-cdc" title="Ir al menu principal" aria-label="Ir al menu principal">
                        <img src="@Url.Content("~/resources/CdC-Logo-Vertical1.png")" alt="CDC Portal" class="logo-cdc-image" />
                    </a>
                    <button type="button"
                            class="sidebar-toggle"
                            id="sidebarToggle"
                            aria-label="Contraer menu lateral"
                            aria-pressed="false"
                            title="Contraer menu lateral">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>

                <div class="sidebar-body">
                    <div class="sidebar-nav-shell">
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link@(isSubirDatos ? " is-active" : string.Empty)"
                                   asp-page="/SubirDatos"
                                   title="Subir Proyeccion de Ventas"
                                   aria-current="@(isSubirDatos ? "page" : null)">
                                    <i class="bi bi-cloud-arrow-up"></i>
                                    <span>Subir Proyección de Ventas</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link@(isConsulta ? " is-active" : string.Empty)"
                                   asp-page="/ConsultaProyecciones"
                                   title="Consultar Proyecciones"
                                   aria-current="@(isConsulta ? "page" : null)">
                                    <i class="bi bi-search"></i>
                                    <span>Consultar Proyecciones</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link@(isProgramacion ? " is-active" : string.Empty)"
                                   asp-page="/ProgramarPedidosSucursales"
                                   title="Programar pedidos por sucursal"
                                   aria-current="@(isProgramacion ? "page" : null)">
                                    <i class="bi bi-calendar-week"></i>
                                    <span>Programar pedidos por sucursal</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-page="/Logout" class="sidebar-logout-form">
                            <button type="submit" class="sidebar-logout" title="Cerrar sesion">
                                <span>Salir</span>
                                <i class="bi bi-power"></i>
                            </button>
                        </form>
                    }
                </div>
            </nav>
        }

        <div class="main-content-area@(hideAppChrome ? " main-content-area-auth" : string.Empty)@(string.IsNullOrWhiteSpace(mainContentClass) ? string.Empty : $" {mainContentClass}")">
            <main role="main" class="main-body@(hideAppChrome ? " main-body-auth" : string.Empty)@(string.IsNullOrWhiteSpace(mainBodyClass) ? string.Empty : $" {mainBodyClass}")">
                <div class="page-frame@(string.IsNullOrWhiteSpace(pageFrameClass) ? string.Empty : $" {pageFrameClass}")">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
