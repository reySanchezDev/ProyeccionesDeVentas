<!DOCTYPE html>
<html lang="es" class="@((string?)ViewData["HtmlClass"] ?? string.Empty)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CDC.ProyeccionVentas.FrontEnd</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CDC.ProyeccionVentas.FrontEnd.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>
<body class="@((string?)ViewData["BodyClass"] ?? string.Empty)">
    @{
        var showSidebar = (bool)(ViewData["ShowSidebar"] ?? false);
        var hideAppChrome = (bool)(ViewData["HideAppChrome"] ?? false);
        var showSidebarShell = showSidebar && !hideAppChrome;
        var appContainerClass = (string?)ViewData["AppContainerClass"] ?? string.Empty;
        var mainContentClass = (string?)ViewData["MainContentClass"] ?? string.Empty;
        var mainBodyClass = (string?)ViewData["MainBodyClass"] ?? string.Empty;
        var pageFrameClass = (string?)ViewData["PageFrameClass"] ?? string.Empty;
        var currentPath = Context?.Request?.Path.Value ?? string.Empty;
        var isSubirDatos = currentPath.EndsWith("/SubirDatos", StringComparison.OrdinalIgnoreCase);
        var isConsulta = currentPath.EndsWith("/ConsultaProyecciones", StringComparison.OrdinalIgnoreCase);
        var isProgramacion = currentPath.EndsWith("/ProgramarPedidosSucursales", StringComparison.OrdinalIgnoreCase);
        var isSubirTicketStaff = currentPath.EndsWith("/SubirTicketStaff", StringComparison.OrdinalIgnoreCase)
            || currentPath.EndsWith("/TicketStaff", StringComparison.OrdinalIgnoreCase);
        var isConsultaTicketStaff = currentPath.EndsWith("/ConsultaTicketStaff", StringComparison.OrdinalIgnoreCase);
    }

    <div id="appContainer"
         class="app-container@(showSidebarShell ? " app-with-sidebar" : string.Empty)@(string.IsNullOrWhiteSpace(appContainerClass) ? string.Empty : $" {appContainerClass}")"
         data-sidebar-collapsible="@(showSidebarShell.ToString().ToLowerInvariant())">
        @if (showSidebarShell)
        {
            <nav class="sidebar-cdc" aria-label="Menu principal">
                <div class="sidebar-header">
                    <a asp-page="/Principal" class="logo-cdc" title="Ir al menu principal" aria-label="Ir al menu principal">
                        <img src="@Url.Content("~/resources/CdC-Logo-Vertical1.png")" alt="CDC Portal" class="logo-cdc-image" />
                    </a>
                    <button type="button"
                            class="sidebar-toggle"
                            id="sidebarToggle"
                            aria-label="Contraer menu lateral"
                            aria-pressed="false"
                            title="Contraer menu lateral">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>

                <div class="sidebar-body">
                    <div class="sidebar-nav-shell">
                        <div class="sidebar-nav-groups">
                            <section class="sidebar-nav-group" data-nav-group data-group-key="proyecciones-ventas" data-group-default-open="false">
                                <button type="button"
                                        class="sidebar-group-toggle"
                                        id="grupo-proyecciones"
                                        data-nav-group-toggle
                                        aria-expanded="true"
                                        aria-controls="grupo-proyecciones-opciones">
                                    <span class="sidebar-group-title">Proyecciones de Ventas</span>
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                                <ul class="nav flex-column" id="grupo-proyecciones-opciones" data-nav-group-panel>
                                    <li class="nav-item">
                                        <a class="nav-link@(isSubirDatos ? " is-active" : string.Empty)"
                                           asp-page="/SubirDatos"
                                           title="Subir Proyeccion"
                                           aria-current="@(isSubirDatos ? "page" : null)">
                                            <i class="bi bi-cloud-arrow-up"></i>
                                            <span>Subir Proyección</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link@(isConsulta ? " is-active" : string.Empty)"
                                           asp-page="/ConsultaProyecciones"
                                           title="Consultar Proyecciones"
                                           aria-current="@(isConsulta ? "page" : null)">
                                            <i class="bi bi-search"></i>
                                            <span>Consultar Proyecciones</span>
                                        </a>
                                    </li>
                                </ul>
                            </section>

                            <section class="sidebar-nav-group" data-nav-group data-group-key="ticket-promedio-staff" data-group-default-open="false">
                                <button type="button"
                                        class="sidebar-group-toggle"
                                        id="grupo-ticket-staff"
                                        data-nav-group-toggle
                                        aria-expanded="true"
                                        aria-controls="grupo-ticket-staff-opciones">
                                    <span class="sidebar-group-title">Ticket Promedio Por Staff</span>
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                                <ul class="nav flex-column" id="grupo-ticket-staff-opciones" data-nav-group-panel>
                                    <li class="nav-item">
                                        <a class="nav-link@(isSubirTicketStaff ? " is-active" : string.Empty)"
                                           asp-page="/SubirTicketStaff"
                                           title="Subir Tickets"
                                           aria-current="@(isSubirTicketStaff ? "page" : null)">
                                            <i class="bi bi-receipt-cutoff"></i>
                                            <span>Subir Tickets</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link@(isConsultaTicketStaff ? " is-active" : string.Empty)"
                                           asp-page="/ConsultaTicketStaff"
                                           title="Consultar Tickets"
                                           aria-current="@(isConsultaTicketStaff ? "page" : null)">
                                            <i class="bi bi-search-heart"></i>
                                            <span>Consultar Tickets</span>
                                        </a>
                                    </li>
                                </ul>
                            </section>

                            <section class="sidebar-nav-group sidebar-nav-group-standalone" data-nav-group data-group-key="programar-pedidos-sucursal" data-group-default-open="false">
                                <button type="button"
                                        class="sidebar-group-toggle"
                                        id="grupo-programacion"
                                        data-nav-group-toggle
                                        aria-expanded="true"
                                        aria-controls="grupo-programacion-opciones">
                                    <span class="sidebar-group-title">Programar Pedidos</span>
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                                <ul class="nav flex-column" id="grupo-programacion-opciones" data-nav-group-panel>
                                    <li class="nav-item">
                                        <a class="nav-link sidebar-nav-link-standalone@(isProgramacion ? " is-active" : string.Empty)"
                                           asp-page="/ProgramarPedidosSucursales"
                                           title="Programar pedidos por sucursal"
                                           aria-current="@(isProgramacion ? "page" : null)">
                                            <i class="bi bi-calendar-week"></i>
                                            <span>Por Sucursales</span>
                                        </a>
                                    </li>
                                </ul>
                            </section>
                        </div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-page="/Logout" class="sidebar-logout-form">
                            <button type="submit" class="sidebar-logout" title="Cerrar sesion">
                                <span>Salir</span>
                                <i class="bi bi-power"></i>
                            </button>
                        </form>
                    }
                </div>
            </nav>
        }

        <div class="main-content-area@(hideAppChrome ? " main-content-area-auth" : string.Empty)@(string.IsNullOrWhiteSpace(mainContentClass) ? string.Empty : $" {mainContentClass}")">
            <main role="main" class="main-body@(hideAppChrome ? " main-body-auth" : string.Empty)@(string.IsNullOrWhiteSpace(mainBodyClass) ? string.Empty : $" {mainBodyClass}")">
                <div class="page-frame@(string.IsNullOrWhiteSpace(pageFrameClass) ? string.Empty : $" {pageFrameClass}")">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
