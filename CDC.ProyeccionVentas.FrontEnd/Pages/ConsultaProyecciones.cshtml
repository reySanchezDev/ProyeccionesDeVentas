@page
@model ConsultaProyeccionesModel
@{
    ViewData["Title"] = "Consulta de Proyecciones";
    ViewData["ShowSidebar"] = true;
    var mesActual = DateTime.Today.Month;
    var totalResultados = Model.Resultados?.Count ?? 0;
}
@{
    decimal totalMonto = 0;
    if (Model.Resultados != null)
    {
        totalMonto = Model.Resultados.Sum(r => r.Monto);
    }
}

<div class="screen-shell consulta-proyecciones-shell">
    <section class="screen-card screen-card-header screen-card-header-compact consulta-proyecciones-header">
        <div class="screen-title-row">
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <span id="mensajeDinamico" class="page-status-message screen-status" aria-live="polite"></span>
        </div>
    </section>

    <form method="post" class="row g-3 mb-4 screen-card screen-card-form" id="form-filtros">
        <div class="col-md-3">
            <label class="form-label">Fecha Inicio</label>
            <input type="date" class="form-control" asp-for="Filtro.FechaInicio" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Fecha Fin</label>
            <input type="date" class="form-control" asp-for="Filtro.FechaFin" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sucursal (opcional)</label>
            <div class="dropdown w-100">
                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start store-filter-toggle"
                        type="button"
                        id="storeFilterDropdownButton"
                        data-bs-toggle="dropdown"
                        data-bs-auto-close="outside"
                        aria-expanded="false">
                    <span id="storeFilterSummary">@Model.ResumenSucursalesSeleccionadas</span>
                </button>
                <div class="dropdown-menu w-100 p-2 store-filter-menu" aria-labelledby="storeFilterDropdownButton">
                    @foreach (var store in Model.StoresDisponibles)
                    {
                        var checkboxId = $"store-filter-{store.No}";
                        <div class="form-check">
                            <input class="form-check-input store-filter-check"
                                   type="checkbox"
                                   name="Filtro.CodSucursales"
                                   value="@store.No"
                                   id="@checkboxId"
                                   @(Model.Filtro.CodSucursales.Contains(store.No) ? "checked" : null) />
                            <label class="form-check-label" for="@checkboxId">@store.No - @store.StoreNo</label>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3 d-flex align-items-end"></div>
    </form>

    <section class="screen-card screen-card-actions">
        <div class="d-flex justify-content-between align-items-center mb-3" id="botonera">
            <div class="btn-group">
                <button type="submit" class="btn btn-primary custom-btn-effect btn-buscar" form="form-filtros">
                    <i class="bi bi-search me-1"></i> Buscar
                </button>
                <button id="btnLimpiar" class="btn btn-outline-secondary custom-btn-effect btn-limpiar">
                    <i class="bi bi-x-circle"></i> Limpiar
                </button>
                <button id="btnRecargar" class="btn btn-outline-primary custom-btn-effect btn-recargar">
                    <i class="bi bi-arrow-clockwise"></i> Recargar
                </button>
                <button id="btnExportarExcel" class="btn btn-outline-success custom-btn-effect btn-exportar" disabled>
                    <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
                </button>
                <button id="btnEliminarMes" type="button" class="btn btn-outline-danger custom-btn-effect btn-eliminar-mes">
                    <i class="bi bi-trash me-1"></i> Eliminar Mes
                </button>
                <span class="badge bg-info text-dark ms-3 fs-6 py-2 px-3 align-self-center badge-filas">
                    Filas: <span id="filasCount">@totalResultados</span>
                </span>
                <span class="badge bg-success fs-6 py-2 px-3 align-self-center badge-total">
                    Total: USD <span id="montoTotal">@totalMonto.ToString("N2")</span>
                </span>
            </div>
        </div>
    </section>

    @if (Model.Resultados != null && Model.Resultados.Any())
    {
        <section class="screen-card screen-card-table">
            <div class="table-responsive-scroll">
                <table class="table table-bordered table-striped mt-2" id="tablaResultados">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:5%;">ID</th>
                            <th style="width:20%;">Fecha Proyección</th>
                            <th style="width:20%;">Sucursal</th>
                            <th style="width:20%;">Monto (USD)</th>
                            <th style="width:20%;">Ticket Promedio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Resultados.Count; i++)
                        {
                            var item = Model.Resultados[i];
                            <tr data-id="@item.Id">
                                <td>@item.Id</td>
                                <td>@item.Fecha.ToString("yyyy-MM-dd")</td>
                                <td>@item.CodSucursal</td>
                                <td>
                                    <input type="text" class="form-control editable-field input-monto"
                                           data-index="@i"
                                           data-field="monto"
                                           inputmode="decimal"
                                           autocomplete="off"
                                           value="@item.Monto.ToString("F2")" />
                                </td>
                                <td>
                                    <input type="text" class="form-control editable-field input-ticket-promedio"
                                           data-index="@i"
                                           data-field="ticketPromedio"
                                           inputmode="numeric"
                                           autocomplete="off"
                                           value="@(item.TicketPromedio?.ToString() ?? string.Empty)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
    else if (Model.MostrarMensajeSinResultados)
    {
        <div class="alert alert-info text-center mt-4">
            No se encontraron resultados para los filtros aplicados.
        </div>
    }
</div>

<div class="modal fade" id="deleteMonthModal" tabindex="-1" aria-labelledby="deleteMonthModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteMonthModalLabel">Eliminar Proyecciones por Mes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="anioEliminar" class="form-label">Año</label>
                    <select id="anioEliminar" class="form-select">
                        <option value="">Seleccione un año</option>
                        @foreach (var anio in Model.AniosEliminar)
                        {
                            if (anio == Model.AnioActual)
                            {
                                <option value="@anio" selected>@anio</option>
                            }
                            else
                            {
                                <option value="@anio">@anio</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="mesEliminar" class="form-label">Mes</label>
                    <select id="mesEliminar" class="form-select">
                        <option value="">Seleccione un mes</option>
                        @foreach (var mes in Model.MesesEliminar)
                        {
                            if (mes.Valor == mesActual)
                            {
                                <option value="@mes.Valor" selected>@char.ToUpper(mes.Nombre[0])@mes.Nombre.Substring(1)</option>
                            }
                            else
                            {
                                <option value="@mes.Valor">@char.ToUpper(mes.Nombre[0])@mes.Nombre.Substring(1)</option>
                            }
                        }
                    </select>
                </div>
                <div class="alert alert-warning mb-0">
                    Esta acción eliminará todas las proyecciones del mes seleccionado para todas las sucursales.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary custom-modal-btn" data-bs-dismiss="modal" id="btnCancelarEliminarMes">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn btn-danger custom-modal-btn" id="btnSolicitarConfirmacionEliminar">
                    <i class="bi bi-trash me-1"></i> Confirmar
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmDeleteModalLabel">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-exclamation-octagon-fill text-danger fs-1 mb-3"></i>
                <p id="textoConfirmacionEliminar">Se eliminarán todas las proyecciones del mes seleccionado. ¿Desea continuar?</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary custom-btn-effect" data-bs-dismiss="modal" id="btnCancelarConfirmacionEliminar">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn btn-danger custom-btn-effect" id="btnConfirmarEliminarFinal">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmClearModal" tabindex="-1" aria-labelledby="confirmClearModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmClearModalLabel">Confirmar Limpiar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-3"></i>
                <p>¿Está seguro que desea limpiar la vista previa?</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-danger custom-btn-effect" data-bs-dismiss="modal" id="btnCancelClearModal">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn btn-success custom-btn-effect" id="btnConfirmClearModal">
                    <i class="bi bi-check-circle me-1"></i> Aceptar
                </button>
            </div>
        </div>
    </div>
</div>


@* Modal para exportar a Excel *@
<div class="modal fade" id="exportExcelModal" tabindex="-1" aria-labelledby="exportExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportExcelModalLabel">Exportar a Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-file-earmark-excel-fill text-success" style="font-size: 4rem; margin-bottom: 1rem;"></i>
                <p style="font-size: 1.1rem; font-weight: 500;">Ingrese el nombre del archivo:</p>
                <input type="text" id="fileNameInput" class="form-control mb-3" value="Proyecciones" />
                <div class="alert alert-warning text-start" role="alert">
                    El archivo se descargará automáticamente en tu carpeta de descargas.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary custom-modal-btn" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn btn-success custom-modal-btn" id="confirmExportExcel">
                    <i class="bi bi-download me-1"></i> Exportar
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script>
        let messageTimeoutId = null;
        const rowSaveStates = new Map();

        const confirmClearModal = new bootstrap.Modal(document.getElementById('confirmClearModal'));
        const btnConfirmClear = document.getElementById('btnConfirmClearModal');
        const btnCancelClear = document.getElementById('btnCancelClearModal');

        const exportExcelModal = new bootstrap.Modal(document.getElementById('exportExcelModal'));
        const deleteMonthModal = new bootstrap.Modal(document.getElementById('deleteMonthModal'));
        const confirmDeleteModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
        const btnConfirmExportExcel = document.getElementById('confirmExportExcel');
        const btnEliminarMes = document.getElementById("btnEliminarMes");
        const btnSolicitarConfirmacionEliminar = document.getElementById("btnSolicitarConfirmacionEliminar");
        const btnConfirmarEliminarFinal = document.getElementById("btnConfirmarEliminarFinal");
        const btnCancelarConfirmacionEliminar = document.getElementById("btnCancelarConfirmacionEliminar");
        const tablaResultados = document.getElementById("tablaResultados");
        const guardarUrl = `${window.location.pathname}?handler=Guardar`;
        const eliminarUrl = `${window.location.pathname}?handler=Eliminar`;
        const tokenAntiforgery = () => document.querySelector("input[name=__RequestVerificationToken]")?.value ?? "";
        const nombresMeses = [
            "",
            "enero",
            "febrero",
            "marzo",
            "abril",
            "mayo",
            "junio",
            "julio",
            "agosto",
            "septiembre",
            "octubre",
            "noviembre",
            "diciembre"
        ];

        const limpiarTimeoutMensaje = () => {
            if (messageTimeoutId) {
                clearTimeout(messageTimeoutId);
                messageTimeoutId = null;
            }
        };

        const mostrarMensaje = (tipo, texto, duracion = 5000) => {
            limpiarTimeoutMensaje();
            const contenedor = document.getElementById("mensajeDinamico");
            contenedor.textContent = texto;
            contenedor.className = `page-status-message is-${tipo}`;

            if (duracion > 0) {
                messageTimeoutId = setTimeout(() => {
                    contenedor.textContent = "";
                    contenedor.className = "page-status-message";
                    messageTimeoutId = null;
                }, duracion);
            }
        };

        const normalizarMonto = (valor) => valor.trim().replace(",", ".");
        const normalizarTicket = (valor) => valor.trim().replace(",", ".");

        const esValorMontoParcialValido = (valor) => {
            const valorNormalizado = valor.replace(",", ".");
            if (!valorNormalizado) return true;
            return /^\d+([.]\d{0,2})?$/.test(valorNormalizado);
        };

        const esValorTicketParcialValido = (valor) => /^\d*$/.test(valor);

        const construirValorEditado = (input, texto) => {
            const inicio = input.selectionStart ?? input.value.length;
            const fin = input.selectionEnd ?? input.value.length;
            return `${input.value.slice(0, inicio)}${texto}${input.value.slice(fin)}`;
        };

        const obtenerMontoNormalizado = (input) => {
            const valor = normalizarMonto(input.value);
            if (!valor) return "";

            const numero = Number(valor);
            return Number.isFinite(numero) ? numero.toFixed(2) : "";
        };

        const obtenerTicketNormalizado = (input, emptyAsZero = false) => {
            const valor = normalizarTicket(input.value);
            if (!valor) return emptyAsZero ? "0" : "";

            const numero = Number(valor);
            if (!Number.isFinite(numero) || !Number.isInteger(numero) || numero < 0) {
                return "";
            }

            return String(numero);
        };

        const obtenerSeleccionEliminar = () => {
            const mes = Number(document.getElementById("mesEliminar")?.value);
            const anio = Number(document.getElementById("anioEliminar")?.value);

            if (!mes || !anio) {
                return null;
            }

            const ultimoDia = new Date(Date.UTC(anio, mes, 0)).getUTCDate();
            return {
                mes,
                anio,
                fechaInicio: `${anio}-${String(mes).padStart(2, "0")}-01`,
                fechaFin: `${anio}-${String(mes).padStart(2, "0")}-${String(ultimoDia).padStart(2, "0")}`,
                etiquetaMes: `${nombresMeses[mes]} ${anio}`
            };
        };

        const validarMontoInput = (input) => {
            const valor = normalizarMonto(input.value);
            const esValido = !!valor && /^\d+([.]\d{0,2})?$/.test(valor) && Number.isFinite(Number(valor)) && Number(valor) >= 0;
            input.classList.toggle("is-invalid", !esValido);
            return esValido;
        };

        const validarTicketInput = (input) => {
            const valor = normalizarTicket(input.value);
            if (!valor) {
                input.classList.remove("is-invalid");
                return true;
            }

            const numero = Number(valor);
            const esValido = Number.isFinite(numero) && Number.isInteger(numero) && numero >= 0;
            input.classList.toggle("is-invalid", !esValido);
            return esValido;
        };

        const obtenerElementosFila = (fila) => ({
            montoInput: fila.querySelector('[data-field="monto"]'),
            ticketInput: fila.querySelector('[data-field="ticketPromedio"]')
        });

        const obtenerEstadoFila = (rowId) => {
            if (!rowSaveStates.has(rowId)) {
                rowSaveStates.set(rowId, {
                    saving: false,
                    queued: null
                });
            }

            return rowSaveStates.get(rowId);
        };

        const actualizarTotalMonto = () => {
            if (!tablaResultados) return;

            let total = 0;
            tablaResultados.querySelectorAll('[data-field="monto"]').forEach(input => {
                const valor = Number(input.dataset.originalValue || "0");
                if (Number.isFinite(valor)) {
                    total += valor;
                }
            });

            const totalElemento = document.getElementById("montoTotal");
            if (totalElemento) {
                totalElemento.innerText = total.toLocaleString("es-NI", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }
        };

        const obtenerMensajeErrorDesdeResponse = async (response) => {
            const contentType = response.headers.get("content-type") || "";
            let errorMessage = `HTTP ${response.status}`;

            if (contentType.includes("application/json")) {
                const errorData = await response.json();
                return errorData.error || errorData.mensaje || errorData.message || errorMessage;
            }

            const errorText = await response.text();
            const errorTextPlano = errorText
                .replace(/<[^>]+>/g, " ")
                .replace(/\s+/g, " ")
                .trim();

            return errorTextPlano || errorMessage;
        };

        const formatearInputDesdeValorGuardado = (input, valorNormalizado) => {
            if (input.dataset.field === "monto") {
                input.value = Number(valorNormalizado).toFixed(2);
                input.dataset.originalValue = Number(valorNormalizado).toFixed(2);
                return;
            }

            input.value = String(Number(valorNormalizado));
            input.dataset.originalValue = String(Number(valorNormalizado));
        };

        const restaurarValorOriginal = (input) => {
            const valorOriginal = input.dataset.originalValue || (input.dataset.field === "monto" ? "0.00" : "0");
            formatearInputDesdeValorGuardado(input, valorOriginal);
            input.classList.remove("is-invalid");
        };

        const manejarKeydownEditable = (event, input) => {
            if (event.ctrlKey || event.metaKey || event.altKey) {
                return;
            }

            const teclasPermitidas = new Set([
                "Backspace",
                "Delete",
                "Tab",
                "Enter",
                "Escape",
                "ArrowLeft",
                "ArrowRight",
                "ArrowUp",
                "ArrowDown",
                "Home",
                "End"
            ]);

            if (teclasPermitidas.has(event.key)) {
                return;
            }

            if (event.key.length !== 1) {
                return;
            }

            const siguienteValor = construirValorEditado(input, event.key);
            const esPermitido = input.dataset.field === "monto"
                ? esValorMontoParcialValido(siguienteValor)
                : esValorTicketParcialValido(siguienteValor);

            if (!esPermitido) {
                event.preventDefault();
            }
        };

        const manejarPasteEditable = (event, input) => {
            const textoPegado = event.clipboardData?.getData("text") ?? "";
            const siguienteValor = construirValorEditado(input, textoPegado);
            const esPermitido = input.dataset.field === "monto"
                ? esValorMontoParcialValido(siguienteValor)
                : esValorTicketParcialValido(siguienteValor);

            if (!esPermitido) {
                event.preventDefault();
            }
        };

        const manejarInputEditable = (input) => {
            if (input.dataset.field === "monto") {
                input.classList.toggle("is-invalid", !esValorMontoParcialValido(input.value));
                return;
            }

            input.classList.toggle("is-invalid", !esValorTicketParcialValido(input.value));
        };

        const construirPayloadRegistro = (fila, campoCambiado) => {
            const rowId = Number(fila.dataset.id);
            const { montoInput, ticketInput } = obtenerElementosFila(fila);

            if (!Number.isInteger(rowId)) {
                throw new Error("No se encontró el Id del registro a actualizar.");
            }

            const montoValido = validarMontoInput(montoInput);
            const ticketValido = validarTicketInput(ticketInput);

            if (campoCambiado === "monto" && !montoValido) {
                return null;
            }

            if (campoCambiado === "ticketPromedio" && !ticketValido) {
                return null;
            }

            const montoActual = montoValido ? obtenerMontoNormalizado(montoInput) : (montoInput.dataset.originalValue || "0.00");
            const ticketActual = ticketValido ? obtenerTicketNormalizado(ticketInput, true) : (ticketInput.dataset.originalValue || "0");

            return {
                id: rowId,
                monto: Number(montoActual),
                ticketPromedio: Number(ticketActual)
            };
        };

        const guardarRegistro = async (fila, campoCambiado, payload) => {
            const rowId = payload.id;
            const estadoFila = obtenerEstadoFila(rowId);
            estadoFila.saving = true;
            fila.dataset.saving = "true";

                mostrarMensaje("info", "Modificando...", 0);

            try {
                const response = await fetch(guardarUrl, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenAntiforgery()
                    },
                    body: JSON.stringify([payload])
                });

                if (!response.ok) {
                    throw new Error(await obtenerMensajeErrorDesdeResponse(response));
                }

                const { montoInput, ticketInput } = obtenerElementosFila(fila);
                const inputActualizado = campoCambiado === "monto" ? montoInput : ticketInput;
                const valorGuardado = campoCambiado === "monto"
                    ? payload.monto.toFixed(2)
                    : String(payload.ticketPromedio);

                formatearInputDesdeValorGuardado(inputActualizado, valorGuardado);
                inputActualizado.classList.remove("is-invalid");

                if (campoCambiado === "monto") {
                    actualizarTotalMonto();
                }

                mostrarMensaje("info", "Modificando...", 1200);
            } catch (error) {
                mostrarMensaje("danger", `Ocurrió un error al guardar los cambios: ${error.message}`);
            } finally {
                estadoFila.saving = false;
                fila.dataset.saving = "false";

                if (estadoFila.queued) {
                    const queued = estadoFila.queued;
                    estadoFila.queued = null;
                    await guardarRegistro(fila, queued.campoCambiado, queued.payload);
                }
            }
        };

        const encolarGuardado = (fila, campoCambiado, payload) => {
            const estadoFila = obtenerEstadoFila(payload.id);

            if (estadoFila.saving) {
                estadoFila.queued = { campoCambiado, payload };
                return;
            }

            void guardarRegistro(fila, campoCambiado, payload);
        };

        const manejarBlurEditable = (input) => {
            const fila = input.closest("tr");
            if (!fila) return;

            const campoCambiado = input.dataset.field;

            if (campoCambiado === "monto" && normalizarMonto(input.value) === "") {
                restaurarValorOriginal(input);
                mostrarMensaje("danger", "Monto (USD) es obligatorio y se restauró el valor anterior.");
                return;
            }

            if (campoCambiado === "ticketPromedio" && normalizarTicket(input.value) === "") {
                input.value = "0";
            }

            const esValido = campoCambiado === "monto"
                ? validarMontoInput(input)
                : validarTicketInput(input);

            if (!esValido) {
                if (campoCambiado === "monto") {
                    restaurarValorOriginal(input);
                }
                mostrarMensaje(
                    "danger",
                    campoCambiado === "monto"
                        ? "Monto (USD) debe ser numérico, mayor o igual a cero y con máximo 2 decimales."
                        : "Ticket Promedio debe ser un número entero mayor o igual a cero."
                );
                return;
            }

            const valorActual = campoCambiado === "monto"
                ? obtenerMontoNormalizado(input)
                : obtenerTicketNormalizado(input, true);

            if (valorActual === input.dataset.originalValue) {
                formatearInputDesdeValorGuardado(input, valorActual);
                input.classList.remove("is-invalid");
                return;
            }

            const payload = construirPayloadRegistro(fila, campoCambiado);
            if (!payload) {
                mostrarMensaje(
                    "danger",
                    campoCambiado === "monto"
                        ? "Monto (USD) debe ser numérico, mayor o igual a cero y con máximo 2 decimales."
                        : "Ticket Promedio debe ser un número entero mayor o igual a cero."
                );
                return;
            }

            encolarGuardado(fila, campoCambiado, payload);
        };

        document.addEventListener("DOMContentLoaded", () => {
            const btnExportar = document.getElementById("btnExportarExcel");
            const storeFilterSummary = document.getElementById("storeFilterSummary");
            const storeFilterChecks = Array.from(document.querySelectorAll(".store-filter-check"));

            const actualizarResumenSucursales = () => {
                if (!storeFilterSummary) return;

                const seleccionadas = storeFilterChecks
                    .filter(check => check.checked)
                    .map(check => check.value);

                if (seleccionadas.length === 0) {
                    storeFilterSummary.textContent = "Todas las sucursales";
                    return;
                }

                if (seleccionadas.length <= 2) {
                    storeFilterSummary.textContent = seleccionadas.join(", ");
                    return;
                }

                storeFilterSummary.textContent = `${seleccionadas.length} sucursales seleccionadas`;
            };

            storeFilterChecks.forEach(check => {
                check.addEventListener("change", actualizarResumenSucursales);
            });

            actualizarResumenSucursales();

            if (tablaResultados && tablaResultados.querySelectorAll("tbody tr").length > 0) {
                btnExportar.disabled = false;

                tablaResultados.querySelectorAll('[data-field="monto"]').forEach(input => {
                    input.dataset.originalValue = obtenerMontoNormalizado(input);
                    input.addEventListener("keydown", (event) => manejarKeydownEditable(event, input));
                    input.addEventListener("paste", (event) => manejarPasteEditable(event, input));
                    input.addEventListener("drop", (event) => event.preventDefault());
                    input.addEventListener("input", () => manejarInputEditable(input));
                    input.addEventListener("blur", () => manejarBlurEditable(input));
                });

                tablaResultados.querySelectorAll('[data-field="ticketPromedio"]').forEach(input => {
                    input.dataset.originalValue = obtenerTicketNormalizado(input, true);
                    input.addEventListener("keydown", (event) => manejarKeydownEditable(event, input));
                    input.addEventListener("paste", (event) => manejarPasteEditable(event, input));
                    input.addEventListener("drop", (event) => event.preventDefault());
                    input.addEventListener("input", () => manejarInputEditable(input));
                    input.addEventListener("blur", () => manejarBlurEditable(input));
                });

                actualizarTotalMonto();
            }
        });


        document.getElementById("btnLimpiar")?.addEventListener("click", function (e) {
            e.preventDefault();
            confirmClearModal.show();
        });

        btnConfirmClear.addEventListener("click", function () {
            confirmClearModal.hide();
            location.href = location.pathname;
        });

        btnCancelClear.addEventListener("click", function () {
            confirmClearModal.hide();
        });

        btnEliminarMes?.addEventListener("click", function () {
            deleteMonthModal.show();
        });

        btnSolicitarConfirmacionEliminar?.addEventListener("click", function () {
            const seleccion = obtenerSeleccionEliminar();

            if (!seleccion) {
                mostrarMensaje("warning", "Debe seleccionar un mes y un año para eliminar.");
                return;
            }

            document.getElementById("textoConfirmacionEliminar").innerText =
                `Se eliminarán todas las proyecciones de ${seleccion.etiquetaMes}. ¿Desea continuar?`;

            deleteMonthModal.hide();
            confirmDeleteModal.show();
        });

        btnCancelarConfirmacionEliminar?.addEventListener("click", function () {
            confirmDeleteModal.hide();
            setTimeout(() => deleteMonthModal.show(), 150);
        });

        btnConfirmarEliminarFinal?.addEventListener("click", async function () {
            const seleccion = obtenerSeleccionEliminar();

            if (!seleccion) {
                confirmDeleteModal.hide();
                mostrarMensaje("warning", "Debe seleccionar un mes y un año válidos.");
                return;
            }

            try {
                const response = await fetch(eliminarUrl, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenAntiforgery()
                    },
                    body: JSON.stringify({
                        fechaInicio: seleccion.fechaInicio,
                        fechaFin: seleccion.fechaFin
                    })
                });

                if (response.ok) {
                    const resultado = await response.json();
                    confirmDeleteModal.hide();
                    deleteMonthModal.hide();

                    mostrarMensaje(
                        resultado.registrosEliminados > 0 ? "success" : "info",
                        resultado.mensaje || "Operación completada."
                    );

                    setTimeout(() => {
                        if (tablaResultados) {
                            document.getElementById("form-filtros").submit();
                        } else {
                            location.reload();
                        }
                    }, 1500);
                } else {
                    const contentType = response.headers.get("content-type") || "";
                    let errorMessage = `HTTP ${response.status}`;

                    if (contentType.includes("application/json")) {
                        const errorData = await response.json();
                        errorMessage = errorData.error || errorData.mensaje || errorData.message || errorMessage;
                    } else {
                        const errorText = await response.text();
                        const errorTextPlano = errorText
                            .replace(/<[^>]+>/g, " ")
                            .replace(/\s+/g, " ")
                            .trim();

                        if (errorTextPlano) {
                            errorMessage = errorTextPlano;
                        }
                    }

                    mostrarMensaje("danger", `Ocurrió un error al eliminar los registros: ${errorMessage}`);
                }
            } catch (error) {
                mostrarMensaje("danger", `Error al comunicarse con el servidor: ${error.message}`);
            }
        });


        document.getElementById("btnRecargar")?.addEventListener("click", function (e) {
            e.preventDefault();
            const fechaInicio = document.querySelector("#Filtro_FechaInicio").value;
            const fechaFin = document.querySelector("#Filtro_FechaFin").value;

            if (!fechaInicio || !fechaFin) {
                mostrarMensaje("warning", "Debe ingresar los filtros para recargar los datos.");
            } else {
                document.getElementById("form-filtros").submit();
            }
        });

        document.getElementById("btnExportarExcel")?.addEventListener("click", function () {
            const filas = document.querySelectorAll("#tablaResultados tbody tr");
            if (filas.length === 0) return;

            exportExcelModal.show();
        });

        btnConfirmExportExcel?.addEventListener("click", function () {
            const filas = document.querySelectorAll("#tablaResultados tbody tr");
            const encabezados = ["Fecha", "Sucursal", "Monto", "Ticket Promedio"];
            const data = [encabezados];

            filas.forEach(fila => {
                const celdas = fila.querySelectorAll("td");
                const filaData = [
                    celdas[1].innerText,
                    celdas[2].innerText,
                    celdas[3].querySelector("input")?.value || "",
                    celdas[4].querySelector("input")?.value || ""
                ];
                data.push(filaData);
            });

            let nombre = document.getElementById("fileNameInput").value;
            if (!nombre) {
                nombre = "Proyecciones";
            }

            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.aoa_to_sheet(data);
            XLSX.utils.book_append_sheet(wb, ws, "Proyecciones");
            XLSX.writeFile(wb, `${nombre}.xlsx`);

            exportExcelModal.hide();
        });
    </script>

}
