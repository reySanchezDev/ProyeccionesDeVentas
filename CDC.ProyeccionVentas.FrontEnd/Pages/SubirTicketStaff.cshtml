@page
@model SubirTicketStaffModel
@{
    ViewData["Title"] = "Subir Ticket Promedio Staff";
    ViewData["ShowSidebar"] = true;
    ViewData["HtmlClass"] = "upload-screen-page";
    ViewData["BodyClass"] = "upload-screen-page";
    ViewData["AppContainerClass"] = "app-container-upload-screen";
    ViewData["MainContentClass"] = "main-content-area-upload-screen";
    ViewData["MainBodyClass"] = "main-body-upload-screen";
    ViewData["PageFrameClass"] = "page-frame-upload-screen";
}

<div class="screen-shell upload-screen-shell"
     id="ticketStaffUploadApp"
     data-month-label="@Model.CurrentMonthLabel">
    <section class="screen-card screen-card-header screen-card-header-compact">
        <div class="screen-title-row">
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <span id="mensajeDinamico" class="page-status-message screen-status upload-screen-status" aria-live="polite"></span>
        </div>
    </section>

    <form method="post" id="ticketStaffUploadAntiForgeryForm" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <section class="screen-card screen-card-form">
        <div class="row g-3">
            <div class="col-12">
                <label for="excelInput" class="form-label">Archivo de carga masiva</label>
                <input type="file"
                       class="form-control custom-btn-effect"
                       id="excelInput"
                       accept=".xlsx,.xls,.xlsm,.csv" />
            </div>
        </div>
    </section>

    <section class="screen-card screen-card-actions">
        <div class="row g-3 align-items-end">
            <div class="col-lg-5 col-xl-4">
                <label class="form-label">Puestos</label>
                <div class="dropdown w-100">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start store-filter-toggle"
                            type="button"
                            id="puestosDropdownButton"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false"
                            @(Model.PuestosDisponibles.Count == 0 ? "disabled" : null)>
                        <span id="puestosFilterSummary">Todos los puestos</span>
                    </button>
                    <div class="dropdown-menu w-100 p-2 store-filter-menu" aria-labelledby="puestosDropdownButton">
                        @foreach (var puesto in Model.PuestosDisponibles)
                        {
                            var checkboxId = $"puesto-filter-{puesto.Replace(" ", "-")}";
                            <div class="form-check">
                                <input class="form-check-input puesto-filter-check"
                                       type="checkbox"
                                       value="@puesto"
                                       id="@checkboxId" />
                                <label class="form-check-label" for="@checkboxId">@puesto</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-7 col-xl-8">
                <div class="d-flex flex-wrap align-items-center gap-2 h-100">
                    <button type="button" class="btn btn-outline-success custom-btn-effect" id="btnDescargarPlantilla" @(Model.PuestosDisponibles.Count == 0 ? "disabled" : null)>
                        <i class="bi bi-file-earmark-excel me-1"></i> Descargar plantilla
                    </button>
                    <button type="button" class="btn btn-primary custom-btn-effect" id="btnLeerArchivo">
                        <i class="bi bi-file-earmark-arrow-up me-1"></i> Leer archivo
                    </button>
                    <button type="button" class="btn btn-success custom-btn-effect" id="btnGuardar" disabled>
                        <i class="bi bi-database-check me-1"></i> Guardar en BD
                    </button>
                    <button type="button" class="btn btn-outline-danger custom-btn-effect" id="btnLimpiar">
                        <i class="bi bi-x-circle me-1"></i> Limpiar
                    </button>
                    <span class="badge bg-info text-dark ms-auto d-none" id="badgeFilas"></span>
                    <span class="badge bg-secondary d-none" id="badgeEmpleados"></span>
                </div>
            </div>
            <div class="col-12 pt-1">
                <div class="form-text mb-0">Puede seleccionar uno o más puestos para filtrar la plantilla del período @Model.CurrentMonthLabel. Si no selecciona ninguno, se descargarán todos.</div>
                @if (!string.IsNullOrWhiteSpace(Model.CatalogoError))
                {
                    <div class="text-danger small mt-2">@Model.CatalogoError</div>
                }
            </div>
        </div>
    </section>

    <section class="screen-card screen-card-table d-none" id="preview">
        <h4 class="upload-preview-title">Vista previa de la carga</h4>
        <div class="scroll-tabla-preview">
            <table class="table table-bordered table-striped mt-2" id="tablaPreviewTicketStaff">
                <thead class="table-dark">
                    <tr>
                        <th>Número Empleado</th>
                        <th>Nombre Staff</th>
                        <th>Puesto</th>
                        <th>Ubicación</th>
                        <th>Proyección Ticket Promedio</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </section>
</div>

<div class="modal fade" id="existingRecordsModal" tabindex="-1" aria-labelledby="existingRecordsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="existingRecordsModalLabel">Registros ya guardados</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3" id="existingRecordsModalMessage">Ya existen registros guardados para uno o más empleados en el mes actual.</p>
                <ul class="mb-0" id="existingRecordsList"></ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary custom-btn-effect" data-bs-dismiss="modal">
                    Entendido
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script>
        const uploadApp = document.getElementById("ticketStaffUploadApp");
        const monthLabel = uploadApp.dataset.monthLabel;
        const excelInput = document.getElementById("excelInput");
        const previewCard = document.getElementById("preview");
        const previewBody = document.querySelector("#tablaPreviewTicketStaff tbody");
        const btnGuardar = document.getElementById("btnGuardar");
        const btnDescargarPlantilla = document.getElementById("btnDescargarPlantilla");
        const badgeFilas = document.getElementById("badgeFilas");
        const badgeEmpleados = document.getElementById("badgeEmpleados");
        const puestosFilterSummary = document.getElementById("puestosFilterSummary");
        const puestosFilterChecks = Array.from(document.querySelectorAll(".puesto-filter-check"));
        const existingRecordsModal = new bootstrap.Modal(document.getElementById("existingRecordsModal"));
        const existingRecordsModalLabel = document.getElementById("existingRecordsModalLabel");
        const existingRecordsModalMessage = document.getElementById("existingRecordsModalMessage");
        const existingRecordsList = document.getElementById("existingRecordsList");
        let messageTimeoutId = null;
        let filasCargadas = [];

        const tokenAntiforgery = () => document.querySelector("input[name=__RequestVerificationToken]")?.value ?? "";
        const repararTextoMojibake = (texto) => {
            if (texto === null || texto === undefined) {
                return "";
            }

            const valor = String(texto);
            if (!/[ÃÂ]/.test(valor)) {
                return valor;
            }

            try {
                const reparado = new TextDecoder("utf-8").decode(Uint8Array.from(valor, caracter => caracter.charCodeAt(0)));
                return reparado.includes("�") && !valor.includes("�") ? valor : reparado;
            } catch {
                return valor;
            }
        };

        const limpiarTimeoutMensaje = () => {
            if (messageTimeoutId) {
                clearTimeout(messageTimeoutId);
                messageTimeoutId = null;
            }
        };

        const mostrarMensaje = (tipo, texto, duracion = 4000) => {
            const contenedor = document.getElementById("mensajeDinamico");
            limpiarTimeoutMensaje();

            if (!texto) {
                contenedor.textContent = "";
                contenedor.className = "page-status-message screen-status upload-screen-status";
                return;
            }

            contenedor.textContent = repararTextoMojibake(texto);
            contenedor.className = `page-status-message screen-status upload-screen-status is-${tipo}`;

            if (duracion > 0) {
                messageTimeoutId = window.setTimeout(() => {
                    contenedor.textContent = "";
                    contenedor.className = "page-status-message screen-status upload-screen-status";
                    messageTimeoutId = null;
                }, duracion);
            }
        };

        const limpiarInterfaz = (limpiarMensaje = true) => {
            filasCargadas = [];
            excelInput.value = "";
            previewBody.innerHTML = "";
            previewCard.classList.add("d-none");
            previewCard.style.display = "none";
            btnGuardar.disabled = true;
            badgeFilas.classList.add("d-none");
            badgeEmpleados.classList.add("d-none");

            if (limpiarMensaje) {
                mostrarMensaje("", "");
            }
        };

        const normalizarCabecera = (valor) => String(valor ?? "")
            .trim()
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/\s+/g, "");

        const parseTicketPromedio = (value) => {
            if (value === null || value === undefined || value === "") {
                return 0;
            }

            if (typeof value === "number") {
                return Number.isInteger(value) && value >= 0 ? value : null;
            }

            const text = String(value).trim();
            if (!text) {
                return 0;
            }

            if (!/^\d+$/.test(text)) {
                return null;
            }

            return Number(text);
        };

        const obtenerPuestosSeleccionados = () => puestosFilterChecks
            .filter(check => check.checked)
            .map(check => check.value.trim())
            .filter(Boolean);

        const actualizarResumenPuestos = () => {
            if (!puestosFilterSummary) {
                return;
            }

            const seleccionados = obtenerPuestosSeleccionados();
            if (seleccionados.length === 0) {
                puestosFilterSummary.textContent = "Todos los puestos";
                return;
            }

            if (seleccionados.length <= 2) {
                puestosFilterSummary.textContent = seleccionados.join(", ");
                return;
            }

            puestosFilterSummary.textContent = `${seleccionados.length} puestos seleccionados`;
        };

        const renderPreview = () => {
            previewBody.innerHTML = filasCargadas.map(item => `
                <tr>
                    <td>${item.numeroEmpleado}</td>
                    <td>${item.nombreStaff || ""}</td>
                    <td>${item.puesto || ""}</td>
                    <td>${item.ubicacion || ""}</td>
                    <td>${item.ticketPromedio}</td>
                </tr>
            `).join("");

            previewCard.classList.remove("d-none");
            previewCard.style.display = "flex";
            badgeFilas.textContent = `Filas: ${filasCargadas.length}`;
            badgeFilas.classList.remove("d-none");

            const totalEmpleados = new Set(filasCargadas.map(item => item.numeroEmpleado)).size;
            badgeEmpleados.textContent = `Staff: ${totalEmpleados}`;
            badgeEmpleados.classList.remove("d-none");
            const previewScroller = previewCard.querySelector(".scroll-tabla-preview");
            if (previewScroller) {
                previewScroller.scrollTop = 0;
            }
        };

        const obtenerMensajeError = async (response) => {
            const contentType = response.headers.get("content-type") || "";
            if (contentType.includes("application/json")) {
                const data = await response.json();
                return repararTextoMojibake(data.error || data.mensaje || data.message || `HTTP ${response.status}`);
            }

            const text = await response.text();
            return repararTextoMojibake(text || `HTTP ${response.status}`);
        };

        const mostrarModalLista = (titulo, mensaje, items) => {
            existingRecordsModalLabel.textContent = titulo;
            existingRecordsModalMessage.textContent = mensaje;
            const detalle = items
                .slice(0, 20)
                .map(item => `<li>${item}</li>`)
                .join("");
            const extra = items.length > 20
                ? `<li>Y ${items.length - 20} coincidencia(s) más...</li>`
                : "";

            existingRecordsList.innerHTML = `${detalle}${extra}`;
            existingRecordsModal.show();
        };

        const construirPayloadPersistencia = () => filasCargadas.map(item => ({
            numeroEmpleado: item.numeroEmpleado,
            ticketPromedio: item.ticketPromedio
        }));

        const validarExistentes = async () => {
            const response = await fetch(`${window.location.pathname}?handler=ValidarExistentes`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": tokenAntiforgery()
                },
                body: JSON.stringify(construirPayloadPersistencia())
            });

            if (!response.ok) {
                throw new Error(await obtenerMensajeError(response));
            }

            return await response.json();
        };

        const procesarArchivo = async () => {
            const file = excelInput.files?.[0];
            if (!file) {
                mostrarMensaje("warning", "Debe seleccionar un archivo antes de leerlo.");
                return;
            }

            limpiarInterfaz(false);
            mostrarMensaje("info", "Validando archivo...", 0);

            try {
                const buffer = await file.arrayBuffer();
                const workbook = XLSX.read(buffer, { type: "array" });
                const firstSheetName = workbook.SheetNames[0];

                if (!firstSheetName) {
                    throw new Error("El archivo no contiene hojas.");
                }

                const rows = XLSX.utils.sheet_to_json(workbook.Sheets[firstSheetName], {
                    header: 1,
                    raw: true,
                    defval: ""
                });

                if (!rows.length) {
                    throw new Error("El archivo no contiene datos.");
                }

                const headers = rows[0].map(normalizarCabecera);
                const numeroEmpleadoIndex = headers.indexOf("numeroempleado");
                const nombreStaffIndex = headers.indexOf("nombrestaff");
                const puestoIndex = headers.indexOf("puesto");
                const ubicacionIndex = headers.indexOf("ubicacion");
                const ticketPromedioIndex = headers.indexOf("ticketpromedio");

                if (numeroEmpleadoIndex === -1 || nombreStaffIndex === -1 || puestoIndex === -1 || ubicacionIndex === -1 || ticketPromedioIndex === -1) {
                    throw new Error("La plantilla debe incluir NumeroEmpleado, NombreStaff, Puesto, Ubicacion y TicketPromedio.");
                }

                const errores = [];
                const registros = [];
                const duplicados = new Set();

                for (let index = 1; index < rows.length; index++) {
                    const row = rows[index];
                    const emptyRow = row.every(cell => String(cell ?? "").trim() === "");
                    if (emptyRow) {
                        continue;
                    }

                    const numeroEmpleado = String(row[numeroEmpleadoIndex] ?? "").trim();
                    if (!numeroEmpleado) {
                        errores.push(`Fila ${index + 1}: NumeroEmpleado es obligatorio.`);
                        continue;
                    }

                    const nombreStaff = String(row[nombreStaffIndex] ?? "").trim();
                    const puesto = String(row[puestoIndex] ?? "").trim();
                    const ubicacion = String(row[ubicacionIndex] ?? "").trim();

                    if (!puesto) {
                        errores.push(`Fila ${index + 1}: Puesto es obligatorio.`);
                        continue;
                    }

                    if (!ubicacion) {
                        errores.push(`Fila ${index + 1}: Ubicacion es obligatoria.`);
                        continue;
                    }

                    const ticketPromedio = parseTicketPromedio(row[ticketPromedioIndex]);
                    if (ticketPromedio === null) {
                        errores.push(`Fila ${index + 1}: TicketPromedio debe ser entero mayor o igual a cero.`);
                        continue;
                    }

                    const llave = numeroEmpleado;
                    if (duplicados.has(llave)) {
                        errores.push(`Fila ${index + 1}: NumeroEmpleado duplicado (${numeroEmpleado}).`);
                        continue;
                    }

                    duplicados.add(llave);
                    registros.push({
                        numeroEmpleado,
                        nombreStaff,
                        puesto,
                        ubicacion,
                        ticketPromedio
                    });
                }

                if (!registros.length) {
                    throw new Error("El archivo no contiene filas válidas para procesar.");
                }

                if (errores.length) {
                    const erroresDuplicados = errores.filter(error => error.includes("duplicado"));
                    if (erroresDuplicados.length === errores.length) {
                        mostrarMensaje("", "");
                        mostrarModalLista(
                            "Registros repetidos en el archivo",
                            "El archivo contiene empleados repetidos dentro del mismo mes.",
                            erroresDuplicados
                        );
                        return;
                    }

                    const primerError = errores[0];
                    mostrarMensaje("danger", `Se detectaron ${errores.length} error(es) de formato. Primer detalle: ${primerError}`);
                    return;
                }

                filasCargadas = registros;
                const existentes = await validarExistentes();

                if (Array.isArray(existentes) && existentes.length > 0) {
                    filasCargadas = [];
                    mostrarMensaje("", "");
                    mostrarModalLista(
                        "Registros ya guardados",
                        `Ya existen registros guardados para uno o más empleados en ${monthLabel}.`,
                        existentes.map(item => `${item.numeroEmpleado} - ${String(item.mes).padStart(2, "0")}/${item.ano}`)
                    );
                    return;
                }

                renderPreview();
                btnGuardar.disabled = false;
                mostrarMensaje("success", "Archivo validado correctamente. Ya puede guardar la carga masiva.");
            } catch (error) {
                filasCargadas = [];
                btnGuardar.disabled = true;
                previewCard.classList.add("d-none");
                previewCard.style.display = "none";
                mostrarMensaje("danger", error.message || "Ocurrió un error al procesar el archivo.");
            }
        };

        const guardarCarga = async () => {
            if (!filasCargadas.length) {
                mostrarMensaje("warning", "No hay filas válidas para guardar.");
                return;
            }

            btnGuardar.disabled = true;
            mostrarMensaje("info", "Guardando carga masiva...", 0);

            try {
                const response = await fetch(`${window.location.pathname}?handler=Guardar`, {
                    method: "POST",
                    headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": tokenAntiforgery()
                },
                body: JSON.stringify({
                    items: construirPayloadPersistencia()
                })
            });

                if (!response.ok) {
                    throw new Error(await obtenerMensajeError(response));
                }

                const resultado = await response.json();
                limpiarInterfaz(false);
                mostrarMensaje("success", resultado.mensaje || "Carga masiva procesada correctamente.");
            } catch (error) {
                btnGuardar.disabled = false;
                mostrarMensaje("danger", error.message || "No se pudo guardar la carga masiva.");
            }
        };

        const descargarPlantilla = async () => {
            const puestos = obtenerPuestosSeleccionados();
            mostrarMensaje("info", "Descargando plantilla...", 0);

            const response = await fetch(`${window.location.pathname}?handler=DescargarPlantilla`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": tokenAntiforgery()
                },
                body: JSON.stringify(puestos)
            });

            if (!response.ok) {
                throw new Error(await obtenerMensajeError(response));
            }

            const data = await response.json();
            if (!Array.isArray(data) || data.length === 0) {
                throw new Error("No se encontraron empleados para los puestos seleccionados.");
            }

            const rows = [
                ["NumeroEmpleado", "NombreStaff", "Puesto", "Ubicacion", "TicketPromedio"],
                ...data.map(item => [
                    item.numeroEmpleado || "",
                    item.nombreStaff || "",
                    item.puesto || "",
                    item.ubicacion || "",
                    item.ticketPromedio ?? ""
                ])
            ];

            const workbook = XLSX.utils.book_new();
            const worksheet = XLSX.utils.aoa_to_sheet(rows);
            XLSX.utils.book_append_sheet(workbook, worksheet, "Plantilla");
            XLSX.writeFile(workbook, `Plantilla_TicketStaff_${monthLabel.replace(/\s+/g, "_")}.xlsx`);
        };

        document.getElementById("btnLeerArchivo")?.addEventListener("click", () => {
            void procesarArchivo();
        });

        btnGuardar?.addEventListener("click", () => {
            void guardarCarga();
        });

        document.getElementById("btnLimpiar")?.addEventListener("click", () => {
            limpiarInterfaz();
        });

        btnDescargarPlantilla?.addEventListener("click", async () => {
            try {
                await descargarPlantilla();
                mostrarMensaje("success", "Plantilla descargada correctamente.");
            } catch (error) {
                mostrarMensaje("danger", error.message || "No se pudo descargar la plantilla.");
            }
        });

        puestosFilterChecks.forEach(check => {
            check.addEventListener("change", () => {
                actualizarResumenPuestos();
            });
        });

        actualizarResumenPuestos();
    </script>
}
